# Git ignore for Perplexity AI backend (updated 2026-03-30)

# Node dependencies
node_modules/
backend/node_modules/

# Environment files (keep examples tracked)
.env
.env.*
backend/.env
backend/.env.*
!.env.example
!backend/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build and coverage outputs
build/
dist/
coverage/
.nyc_output/

# Caches
.cache/
.eslintcache

# OS files
.DS_Store
Thumbs.db

# IDE/editor
.idea/
.vscode/
*.iml